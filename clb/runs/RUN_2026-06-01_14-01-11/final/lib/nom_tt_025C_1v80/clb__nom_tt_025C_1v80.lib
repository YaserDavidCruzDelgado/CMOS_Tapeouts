          values("0.01780,0.02057,0.02791,0.04572,0.09387,0.24221,0.69494");
	}
      }
      timing() {
        related_pin : "I[3]";
        timing_sense : positive_unate;
        timing_type : combinational;
	cell_rise(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.43119,0.43620,0.44823,0.47764,0.55815,0.79098,1.48079");
	}
	rise_transition(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.01767,0.02204,0.03441,0.07142,0.18464,0.52107,1.50769");
	}
	cell_fall(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.39939,0.40428,0.41455,0.43563,0.48095,0.59707,0.93145");
