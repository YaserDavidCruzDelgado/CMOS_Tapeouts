          values("0.41645,0.42135,0.43162,0.45270,0.49802,0.61414,0.94853");
	}
	fall_transition(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.01781,0.02057,0.02791,0.04572,0.09386,0.24218,0.69491");
	}
      }
      timing() {
        related_pin : "I[3]";
        timing_sense : positive_unate;
        timing_type : combinational;
	cell_rise(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.43544,0.44045,0.45248,0.48189,0.56240,0.79518,1.48536");
	}
	rise_transition(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.01769,0.02206,0.03443,0.07142,0.18466,0.52108,1.50772");
	}
	cell_fall(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.40200,0.40690,0.41717,0.43825,0.48357,0.59969,0.93408");
	}
