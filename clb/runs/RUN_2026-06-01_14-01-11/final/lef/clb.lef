  END rst
  OBS
      LAYER nwell ;
        RECT 5.330 10.795 59.530 51.870 ;
      LAYER li1 ;
        RECT 5.520 10.795 59.340 51.765 ;
      LAYER met1 ;
        RECT 5.520 10.640 59.340 51.920 ;
      LAYER met2 ;
        RECT 6.530 4.280 43.460 51.865 ;
        RECT 7.090 4.000 9.470 4.280 ;
        RECT 10.310 4.000 12.690 4.280 ;
        RECT 13.530 4.000 15.910 4.280 ;
        RECT 16.750 4.000 32.010 4.280 ;
