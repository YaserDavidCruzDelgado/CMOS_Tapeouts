VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN clb ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 65000 65000 ) ;
ROW ROW_0 unithd 5520 10880 N DO 117 BY 1 STEP 460 0 ;
ROW ROW_1 unithd 5520 13600 FS DO 117 BY 1 STEP 460 0 ;
ROW ROW_2 unithd 5520 16320 N DO 117 BY 1 STEP 460 0 ;
ROW ROW_3 unithd 5520 19040 FS DO 117 BY 1 STEP 460 0 ;
ROW ROW_4 unithd 5520 21760 N DO 117 BY 1 STEP 460 0 ;
ROW ROW_5 unithd 5520 24480 FS DO 117 BY 1 STEP 460 0 ;
ROW ROW_6 unithd 5520 27200 N DO 117 BY 1 STEP 460 0 ;
ROW ROW_7 unithd 5520 29920 FS DO 117 BY 1 STEP 460 0 ;
ROW ROW_8 unithd 5520 32640 N DO 117 BY 1 STEP 460 0 ;
ROW ROW_9 unithd 5520 35360 FS DO 117 BY 1 STEP 460 0 ;
ROW ROW_10 unithd 5520 38080 N DO 117 BY 1 STEP 460 0 ;
ROW ROW_11 unithd 5520 40800 FS DO 117 BY 1 STEP 460 0 ;
ROW ROW_12 unithd 5520 43520 N DO 117 BY 1 STEP 460 0 ;
ROW ROW_13 unithd 5520 46240 FS DO 117 BY 1 STEP 460 0 ;
ROW ROW_14 unithd 5520 48960 N DO 117 BY 1 STEP 460 0 ;
TRACKS X 230 DO 141 STEP 460 LAYER li1 ;
TRACKS Y 170 DO 191 STEP 340 LAYER li1 ;
TRACKS X 170 DO 191 STEP 340 LAYER met1 ;
TRACKS Y 170 DO 191 STEP 340 LAYER met1 ;
TRACKS X 230 DO 141 STEP 460 LAYER met2 ;
TRACKS Y 230 DO 141 STEP 460 LAYER met2 ;
TRACKS X 340 DO 95 STEP 680 LAYER met3 ;
TRACKS Y 340 DO 95 STEP 680 LAYER met3 ;
TRACKS X 460 DO 70 STEP 920 LAYER met4 ;
TRACKS Y 460 DO 70 STEP 920 LAYER met4 ;
TRACKS X 1700 DO 19 STEP 3400 LAYER met5 ;
TRACKS Y 1700 DO 19 STEP 3400 LAYER met5 ;
COMPONENTS 2 ;
    - _0_ sky130_fd_sc_hd__and2_2 ;
    - _1_ sky130_fd_sc_hd__conb_1 ;
END COMPONENTS
PINS 10 ;
    - I[0] + NET I[0] + DIRECTION INPUT + USE SIGNAL ;
    - I[1] + NET I[1] + DIRECTION INPUT + USE SIGNAL ;
    - I[2] + NET I[2] + DIRECTION INPUT + USE SIGNAL ;
    - I[3] + NET I[3] + DIRECTION INPUT + USE SIGNAL ;
    - O + NET O + DIRECTION OUTPUT + USE SIGNAL ;
    - cin + NET cin + DIRECTION INPUT + USE SIGNAL ;
    - clk + NET clk + DIRECTION INPUT + USE SIGNAL ;
    - cout + NET cout + DIRECTION OUTPUT + USE SIGNAL ;
    - ff_en + NET ff_en + DIRECTION INPUT + USE SIGNAL ;
    - rst + NET rst + DIRECTION INPUT + USE SIGNAL ;
END PINS
SPECIALNETS 2 ;
    - VGND ( _1_ VNB ) ( _0_ VNB ) ( _1_ VGND ) ( _0_ VGND ) + USE GROUND ;
    - VPWR ( _1_ VPB ) ( _0_ VPB ) ( _1_ VPWR ) ( _0_ VPWR ) + USE POWER ;
END SPECIALNETS
NETS 10 ;
    - I[0] ( PIN I[0] ) + USE SIGNAL ;
    - I[1] ( PIN I[1] ) + USE SIGNAL ;
    - I[2] ( PIN I[2] ) + USE SIGNAL ;
    - I[3] ( PIN I[3] ) ( _0_ A ) + USE SIGNAL ;
    - O ( PIN O ) ( _1_ LO ) + USE SIGNAL ;
    - cin ( PIN cin ) ( _0_ B ) + USE SIGNAL ;
    - clk ( PIN clk ) + USE SIGNAL ;
    - cout ( PIN cout ) ( _0_ X ) + USE SIGNAL ;
    - ff_en ( PIN ff_en ) + USE SIGNAL ;
    - rst ( PIN rst ) + USE SIGNAL ;
END NETS
END DESIGN
