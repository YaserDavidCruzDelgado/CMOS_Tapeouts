          values("0.01778,0.02059,0.02791,0.04573,0.09388,0.24226,0.69499");
	}
      }
      timing() {
        related_pin : "I[3]";
        timing_sense : positive_unate;
        timing_type : combinational;
	cell_rise(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.42476,0.42977,0.44179,0.47122,0.55173,0.78464,1.47368");
	}
	rise_transition(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.01762,0.02199,0.03438,0.07140,0.18461,0.52106,1.50764");
	}
	cell_fall(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.39551,0.40037,0.41065,0.43171,0.47705,0.59316,0.92753");
