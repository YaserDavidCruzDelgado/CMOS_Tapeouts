          values("0.83211,0.84201,0.86607,0.91968,1.05562,1.47695,2.87002");
	}
	fall_transition(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.03261,0.03941,0.05709,0.10706,0.27042,0.84130,2.74461");
	}
      }
      timing() {
        related_pin : "I[3]";
        timing_sense : positive_unate;
        timing_type : combinational;
	cell_rise(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.78222,0.79247,0.81924,0.89152,1.11695,1.85705,4.32355");
	}
	rise_transition(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.03064,0.03943,0.06673,0.15761,0.47292,1.52759,5.00173");
	}
	cell_fall(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.79854,0.80844,0.83250,0.88611,1.02205,1.44338,2.83644");
	}
	fall_transition(template_1) {
