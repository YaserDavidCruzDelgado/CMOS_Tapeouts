VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN control_unit ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 50000 50000 ) ;
ROW ROW_0 unithd 5520 10880 N DO 84 BY 1 STEP 460 0 ;
ROW ROW_1 unithd 5520 13600 FS DO 84 BY 1 STEP 460 0 ;
ROW ROW_2 unithd 5520 16320 N DO 84 BY 1 STEP 460 0 ;
ROW ROW_3 unithd 5520 19040 FS DO 84 BY 1 STEP 460 0 ;
ROW ROW_4 unithd 5520 21760 N DO 84 BY 1 STEP 460 0 ;
ROW ROW_5 unithd 5520 24480 FS DO 84 BY 1 STEP 460 0 ;
ROW ROW_6 unithd 5520 27200 N DO 84 BY 1 STEP 460 0 ;
ROW ROW_7 unithd 5520 29920 FS DO 84 BY 1 STEP 460 0 ;
ROW ROW_8 unithd 5520 32640 N DO 84 BY 1 STEP 460 0 ;
ROW ROW_9 unithd 5520 35360 FS DO 84 BY 1 STEP 460 0 ;
TRACKS X 230 DO 109 STEP 460 LAYER li1 ;
TRACKS Y 170 DO 147 STEP 340 LAYER li1 ;
TRACKS X 170 DO 147 STEP 340 LAYER met1 ;
TRACKS Y 170 DO 147 STEP 340 LAYER met1 ;
TRACKS X 230 DO 109 STEP 460 LAYER met2 ;
TRACKS Y 230 DO 109 STEP 460 LAYER met2 ;
TRACKS X 340 DO 73 STEP 680 LAYER met3 ;
TRACKS Y 340 DO 73 STEP 680 LAYER met3 ;
TRACKS X 460 DO 54 STEP 920 LAYER met4 ;
TRACKS Y 460 DO 54 STEP 920 LAYER met4 ;
TRACKS X 1700 DO 14 STEP 3400 LAYER met5 ;
TRACKS Y 1700 DO 14 STEP 3400 LAYER met5 ;
COMPONENTS 8 ;
    - _2_ sky130_fd_sc_hd__inv_2 ;
    - _3_ sky130_fd_sc_hd__or2_2 ;
    - _4_ sky130_fd_sc_hd__and2_2 ;
    - _5_ sky130_fd_sc_hd__o21ba_2 ;
    - _6_ sky130_fd_sc_hd__xor2_2 ;
    - _7_ sky130_fd_sc_hd__inv_2 ;
    - _8_ sky130_fd_sc_hd__dfrtp_2 ;
    - _9_ sky130_fd_sc_hd__dfrtp_2 ;
END COMPONENTS
PINS 7 ;
    - busy + NET busy + DIRECTION OUTPUT + USE SIGNAL ;
    - clk + NET clk + DIRECTION INPUT + USE SIGNAL ;
    - done + NET done + DIRECTION OUTPUT + USE SIGNAL ;
    - rst + NET rst + DIRECTION INPUT + USE SIGNAL ;
    - start + NET start + DIRECTION INPUT + USE SIGNAL ;
    - state_out[0] + NET state_out[0] + DIRECTION OUTPUT + USE SIGNAL ;
    - state_out[1] + NET state_out[1] + DIRECTION OUTPUT + USE SIGNAL ;
END PINS
SPECIALNETS 2 ;
    - VGND ( _9_ VNB ) ( _8_ VNB ) ( _7_ VNB ) ( _6_ VNB ) ( _5_ VNB ) ( _4_ VNB ) ( _3_ VNB )
      ( _2_ VNB ) ( _9_ VGND ) ( _8_ VGND ) ( _7_ VGND ) ( _6_ VGND ) ( _5_ VGND ) ( _4_ VGND ) ( _3_ VGND )
      ( _2_ VGND ) + USE GROUND ;
    - VPWR ( _9_ VPB ) ( _8_ VPB ) ( _7_ VPB ) ( _6_ VPB ) ( _5_ VPB ) ( _4_ VPB ) ( _3_ VPB )
      ( _2_ VPB ) ( _9_ VPWR ) ( _8_ VPWR ) ( _7_ VPWR ) ( _6_ VPWR ) ( _5_ VPWR ) ( _4_ VPWR ) ( _3_ VPWR )
      ( _2_ VPWR ) + USE POWER ;
END SPECIALNETS
NETS 11 ;
    - _0_ ( _8_ RESET_B ) ( _2_ Y ) + USE SIGNAL ;
    - _1_ ( _9_ RESET_B ) ( _7_ Y ) + USE SIGNAL ;
    - busy ( PIN busy ) ( _3_ X ) + USE SIGNAL ;
    - clk ( PIN clk ) ( _9_ CLK ) ( _8_ CLK ) + USE SIGNAL ;
    - done ( PIN done ) ( _4_ X ) + USE SIGNAL ;
    - next_state\[0\] ( _8_ D ) ( _5_ X ) + USE SIGNAL ;
    - next_state\[1\] ( _9_ D ) ( _6_ X ) + USE SIGNAL ;
    - rst ( PIN rst ) ( _7_ A ) ( _2_ A ) + USE SIGNAL ;
    - start ( PIN start ) ( _5_ A2 ) + USE SIGNAL ;
    - state_out[0] ( PIN state_out[0] ) ( _8_ Q ) ( _6_ A ) ( _5_ B1_N ) ( _4_ A ) ( _3_ A ) + USE SIGNAL ;
    - state_out[1] ( PIN state_out[1] ) ( _9_ Q ) ( _6_ B ) ( _5_ A1 ) ( _4_ B ) ( _3_ B ) + USE SIGNAL ;
END NETS
END DESIGN
